{
  "realm": "connectlens",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "viewer", "description": "Read-only access to ConnectLens" },
      { "name": "operator", "description": "Can perform connector actions (pause/resume/restart)" },
      { "name": "admin", "description": "Full administrative access" }
    ]
  },
  "clients": [
    {
      "clientId": "connectlens-frontend",
      "name": "ConnectLens Frontend (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["http://localhost:8080"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/*"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@connectlens.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "operator",
      "enabled": true,
      "emailVerified": true,
      "email": "operator@connectlens.local",
      "firstName": "Operator",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "operator", "temporary": false }
      ],
      "realmRoles": ["operator"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "emailVerified": true,
      "email": "viewer@connectlens.local",
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "viewer", "temporary": false }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
