# ConnectLens — example environment.
# Copy to .env (docker compose reads .env automatically):
#     cp .env.example .env
#
# The compose file currently hard-codes the demo values below so `docker compose
# up` works with zero config. These variables document the knobs you would
# externalize for a non-demo deployment; wire them into docker-compose.yml with
# ${VAR} interpolation if you want them to take effect.

# ---- Kafka -----------------------------------------------------------------
# Fixed KRaft cluster id (single node). Only change on a fresh volume.
CLUSTER_ID=connectlens-kraft-0001

# ---- Postgres (demo source) ------------------------------------------------
POSTGRES_DB=inventory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- Splunk (demo sink) ----------------------------------------------------
# Web UI login is admin / SPLUNK_PASSWORD. HEC token is a well-known demo value
# and MUST match the token used by the seed connectors.
SPLUNK_PASSWORD=Chang3d!
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000

# ---- Keycloak (OIDC) -------------------------------------------------------
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Browser-facing issuer host. Keycloak mints issuer <KC_HOSTNAME>/realms/connectlens.
KC_HOSTNAME=http://localhost:8081

# ---- Backend (cluster registry + OIDC) -------------------------------------
CONNECTLENS_CLUSTERS_0_ID=local
CONNECTLENS_CLUSTERS_0_NAME=Local Dev
CONNECTLENS_CLUSTERS_0_BOOTSTRAP=kafka:9092
CONNECTLENS_CLUSTERS_0_CONNECT=http://connect:8083
# Issuer as seen by the browser; JWKS reached in-network by the backend.
CONNECTLENS_OIDC_ISSUER=http://localhost:8081/realms/connectlens
CONNECTLENS_OIDC_JWKS=http://keycloak:8080/realms/connectlens/protocol/openid-connect/certs

# Multi-cluster: add a second target by incrementing the index, e.g.
# CONNECTLENS_CLUSTERS_1_ID=staging
# CONNECTLENS_CLUSTERS_1_NAME=Staging
# CONNECTLENS_CLUSTERS_1_BOOTSTRAP=staging-kafka:9092
# CONNECTLENS_CLUSTERS_1_CONNECT=http://staging-connect:8083

# ---- Datagen ---------------------------------------------------------------
# Seconds between INSERT/UPDATE bursts against public.customers.
INTERVAL_SECONDS=5
