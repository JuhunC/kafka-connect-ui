# ConnectLens application-only stack — copy to `.env` and edit.
#   docker compose -f docker-compose.app.yml up -d

# ── Your existing Kafka + Kafka Connect (what the app connects to) ───────────
# IMPORTANT: these must be reachable FROM the backend container.
#  - Services on this machine        -> host.docker.internal:<port>
#  - A remote cluster                 -> real hostname / IP
# Also make sure your Kafka advertises a listener the backend container can
# resolve (NOT "localhost"), and your Connect REST URL is reachable.
CLUSTER_ID=prod
CLUSTER_NAME=Production
KAFKA_BOOTSTRAP=host.docker.internal:9092
CONNECT_URL=http://host.docker.internal:8083

# Multi-cluster: add a second target with indexed env vars, e.g. put these in
# the backend `environment:` block of docker-compose.app.yml:
#   CONNECTLENS_CLUSTERS_1_ID: staging
#   CONNECTLENS_CLUSTERS_1_NAME: Staging
#   CONNECTLENS_CLUSTERS_1_BOOTSTRAP: staging-kafka:9092
#   CONNECTLENS_CLUSTERS_1_CONNECT: http://staging-connect:8083

# ── App image tag (from ghcr.io/juhunc/connectlens-*) ────────────────────────
CONNECTLENS_TAG=latest

# ── Ports on your host ───────────────────────────────────────────────────────
FRONTEND_PORT=8080

# ── Bundled Keycloak (the app's identity provider) ───────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Demo login users come from keycloak/realm-export.json:
#   admin/admin (ADMIN)  ·  operator/operator (OPERATOR)  ·  viewer/viewer (VIEWER)

# ── Using your OWN OIDC provider instead of the bundled Keycloak ─────────────
# Set these to your issuer + JWKS, AND rebuild the frontend image with
# VITE_OIDC_AUTHORITY / VITE_OIDC_CLIENT_ID (the SPA bakes OIDC config at build).
# OIDC_ISSUER=https://sso.example.com/realms/yourrealm
# OIDC_JWKS=https://sso.example.com/realms/yourrealm/protocol/openid-connect/certs
